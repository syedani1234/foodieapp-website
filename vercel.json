{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/server.js" },
    { "src": "/uploads/(.*)", "dest": "backend/server.js" },
    { "src": "/restaurants(.*)", "dest": "backend/server.js" },
    { "src": "/deals(/?.*)", "dest": "backend/server.js" },
    { "src": "/cuisines/([^/]+)", "dest": "backend/server.js" },
    { "src": "/assets/(.*)", "dest": "/frontend/assets/$1" },
    { "src": "/manifest.json", "dest": "/frontend/manifest.json" },
    { "src": "/favicon.ico", "dest": "/frontend/favicon.ico" },
    { "src": "/robots.txt", "dest": "/frontend/robots.txt" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/frontend/index.html" }
  ]
}
